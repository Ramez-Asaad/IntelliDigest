GROQ_API_KEY=your_groq_api_key_here
NEWSAPI_KEY=your_newsapi_key_here

# When Groq rate-limits or errors, the app falls back to a local Ollama model.
# Install: https://ollama.com — then: ollama serve  and  ollama pull qwen2.5:0.5b
# (or set OLLAMA_FALLBACK_MODEL to a tag you have, e.g. qwen2.5:0.5b)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_FALLBACK_MODEL=qwen2.5:0.5b

# Support agent (tool-calling): defaults to llama-3.3-70b-versatile (recommended on Groq).
# Smaller models often raise "Failed to call a function" with AgentExecutor.
# SUPPORT_LLM_MODEL=llama-3.3-70b-versatile
# SUPPORT_LLM_TEMPERATURE=0.25

# Support tickets SQLite DB is created at data/tickets.db (ignored by git)

# Optional: default n8n webhook for Telegram (UI can override). Falls back to N8N_WEBHOOK_URL.
# N8N_TELEGRAM_WEBHOOK_URL=https://your-n8n-host/webhook/telegram-save
# N8N_WEBHOOK_URL=https://your-n8n-host/webhook/legacy
