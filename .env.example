GROQ_API_KEY=your_groq_api_key_here
NEWSAPI_KEY=your_newsapi_key_here

# Optional: single root for Chroma + SQLite (e.g. Fly.io volume at /data). See paths.py and fly.toml.
# INTELLIDIGEST_PERSIST_DIR=/data

# Auth (required for /api/auth/register and /api/auth/login). Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Google sign-in: https://console.cloud.google.com/apis/credentials — OAuth client (Web application).
# In Google Console, Authorized redirect URI must be exactly:
#   http://127.0.0.1:8000/api/auth/google/callback   (adjust host/port)
# In .env, OAUTH_* must be ORIGIN ONLY (scheme + host + port) — do NOT paste the full /callback URL here
# (the app appends /api/auth/google/callback itself). Wrong: .../callback in OAUTH_REDIRECT_BASE → redirect_uri_mismatch.
# localhost and 127.0.0.1 use different cookies; the app aligns loopback origins when env and browser disagree.
# Add both redirect URIs in Google Console if you switch hosts.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# OAUTH_REDIRECT_BASE=http://127.0.0.1:8000
# OAUTH_FRONTEND_REDIRECT_BASE=http://127.0.0.1:8000
# SESSION_SECRET=  # optional; defaults to JWT_SECRET (OAuth state cookie)
# OAUTH_JWT_LEEWAY=600  # optional; seconds of clock skew for Google id_token (default 600). If you see
#   "issued in the future", sync Windows time (Settings → Time → Sync now) or raise this value.

# Password reset (email via SMTP). Links use PASSWORD_RESET_FRONTEND_BASE + /?recovery=...
# PASSWORD_RESET_EXPIRE_MINUTES=60
# PASSWORD_RESET_FRONTEND_BASE=http://127.0.0.1:8000
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@yourdomain.com

# Production: comma-separated browser origins for CORS (omit or leave unset = allow all, dev only).
# Example: ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
# ALLOWED_ORIGINS=

# When Groq rate-limits or errors, the app falls back to a local Ollama model.
# Install: https://ollama.com — then: ollama serve  and  ollama pull qwen2.5:0.5b
# (or set OLLAMA_FALLBACK_MODEL to a tag you have, e.g. qwen2.5:0.5b)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_FALLBACK_MODEL=qwen2.5:0.5b

# Support agent (tool-calling): defaults to llama-3.3-70b-versatile (recommended on Groq).
# Smaller models often raise "Failed to call a function" with AgentExecutor.
# SUPPORT_LLM_MODEL=llama-3.3-70b-versatile
# SUPPORT_LLM_TEMPERATURE=0.25

# Support tickets SQLite DB is created at data/tickets.db (ignored by git)

# Optional: default n8n webhook for Telegram (UI can override). Falls back to N8N_WEBHOOK_URL.
# N8N_TELEGRAM_WEBHOOK_URL=https://your-n8n-host/webhook/telegram-save
# N8N_WEBHOOK_URL=https://your-n8n-host/webhook/legacy
